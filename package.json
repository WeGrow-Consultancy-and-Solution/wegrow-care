{
  "name": "care-at-ease",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:frontend": "vite --port=3000 --host=0.0.0.0",
    "dev:backend": "tsx server.ts",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "mobile:sync": "npm run build && npx cap sync",
    "mobile:open:android": "npx cap open android",
    "mobile:assets": "npx @capacitor/assets generate --android"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
